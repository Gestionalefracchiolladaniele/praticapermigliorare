# Copia in .env e valorizza. .env NON va committato (vedi .gitignore).

# Postgres v0. In locale via Docker (step 6 del piano). Il ruolo NON-superuser
# bizquery_app è quello che l'app deve usare a runtime perché la RLS sia applicata.
# Per il seed (creazione tabelle) serve invece un ruolo owner/superuser.
DATABASE_URL=postgresql://bizquery_app:bizquery_app_pw@localhost:5432/bizquery

# Usato solo da seed.py e per applicare lo schema (owner). In dev può coincidere
# col superuser 'postgres' del container.
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5432/bizquery

# Google AI Studio — free tier. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modello per la generazione SQL (Flash Lite = veloce/gratis su free tier)
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Langfuse (Livello 2 — observability/tracing) -------------------------
# Free tier "Hobby" (50k eventi/mese). Registrati su https://cloud.langfuse.com
# (scegli region EU), crea un progetto, poi Settings -> API Keys -> Create.
# Ti darà i tre valori qui sotto. Se questi restano VUOTI, l'app funziona
# identica ma senza tracing (il tracing si auto-disattiva, niente errori).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Host della region scelta in fase di registrazione:
#   EU -> https://cloud.langfuse.com   |   US -> https://us.cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com

# --- AWS deploy (Livello 1 step 7 — vedi DEPLOY_AWS.md) -------------------
# Il deploy è UN'istanza EC2 t3.micro (free tier) che gira `docker compose up`.
# Queste variabili servono a TE, in locale, per build+push dell'immagine e per
# raggiungere l'istanza. NON vanno nell'immagine e NON servono all'app a runtime
# (sull'istanza serve solo GEMINI_API_KEY, come dice DEPLOY_AWS.md).
#
# Registry per l'immagine. Se usi ECR (500 MB/mese gratis), l'URL è del tipo
#   <account_id>.dkr.ecr.<region>.amazonaws.com/bizquery
# Se usi Docker Hub pubblico:  <tuo-username>/bizquery
AWS_REGION=eu-west-1
ECR_REPOSITORY=bizquery
# IP pubblico (o DNS) dell'istanza EC2 una volta lanciata. Lo riempi dopo il
# passo 2 di DEPLOY_AWS.md. Usato per SSH e per curl di verifica su :8000.
EC2_HOST=
# Utente SSH dell'AMI: Amazon Linux 2023 -> ec2-user ; Ubuntu -> ubuntu
EC2_USER=ec2-user
# Percorso locale della chiave privata .pem scaricata da AWS al lancio dell'istanza.
EC2_SSH_KEY_PATH=

# --- CI/CD (Livello 2 — GitHub Actions) ----------------------------------
# ATTENZIONE: questi NON sono variabili d'ambiente locali. Sono i "Secrets" da
# impostare su GitHub (repo -> Settings -> Secrets and variables -> Actions).
# Li elenco qui solo come CHECKLIST di cosa dovrai creare là, per non dimenticarne
# nessuno. NON metterli nel .env dell'app.
#   AWS_ACCESS_KEY_ID       -> credenziali IAM per push su ECR / deploy
#   AWS_SECRET_ACCESS_KEY   -> (coppia della precedente)
#   EC2_HOST                -> stesso IP di sopra, per lo step di deploy via SSH
#   EC2_SSH_KEY             -> contenuto della .pem (non il path), per SSH dalla CI
#   GEMINI_API_KEY          -> se la CI esegue eval/integration test
